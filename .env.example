# Backend configuration. Keep this single file in the repository root for local development.
ASK_KOCHI_ENVIRONMENT=development
ASK_KOCHI_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
ASK_KOCHI_GEMINI_API_KEY=
ASK_KOCHI_GENERATION_MODEL=gemini-3.1-flash-lite
ASK_KOCHI_MAX_GENERATION_TOKENS=350

# Leave blank locally to use the Vite API proxy. Set this in Vercel for production.
VITE_API_BASE_URL=
